# Copy this to .env for local development (never commit .env)
# Run node scripts/auth.js to get the LinkedIn values

ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn OAuth (from Developer Portal)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# LinkedIn access token (60-day TTL — run scripts/auth.js to generate)
LINKEDIN_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=2026-08-27T10:00:00Z
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXX

# Optional: GitHub fine-grained token for dashboard write-back
# GITHUB_TOKEN=
